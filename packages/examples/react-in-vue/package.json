{
  "name": "react-in-vue",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "home",
    "layout"
  ],
  "scripts": {
    "build": "pnpm  --parallel --filter \"./**\" --filter \"!.\" build",
    "serve": "pnpm  --parallel --filter \"./**\" --filter \"!.\" serve",
    "stop": "kill-port --port 5000,5001"
  },
  "devDependencies": {
    "@hugs7/vite-plugin-federation": "workspace:*",
    "kill-port": "^2.0.1"
  }
}
