{
  "name": "@hugs7/vite-plugin-federation",
  "version": "1.8.4",
  "description": "A Vite plugin which support Module Federation.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./types/index.d.ts",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "types",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hugs7/vite-plugin-federation.git"
  },
  "keywords": [
    "vite",
    "plugins"
  ],
  "author": {
    "name": "@hugs7",
    "url": "https://github.com/hugs7"
  },
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/hugs7/vite-plugin-federation/issues"
  },
  "homepage": "https://github.com/hugs7/vite-plugin-federation#readme",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s --commit-path ."
  },
  "dependencies": {
    "es-module-lexer": "^2.0.0",
    "estree-walker": "^3.0.2",
    "magic-string": "^0.30.0"
  },
  "devDependencies": {
    "@rollup/plugin-virtual": "^3.0.1",
    "@types/estree": "^1.0.0",
    "conventional-changelog-cli": "^4.1.0",
    "typescript": "~5.9.3",
    "vite": "^7.0.0 || ^8.0.0"
  }
}
